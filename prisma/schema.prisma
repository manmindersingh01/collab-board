// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id  String  @id @default(cuid()) 
  email String @unique
  name String
  avatarUrl String?
  clerkId String @unique
  boardMember BoardMember[]
  boards Board[]
  cards Card[]
  comments Comment[]
  activityLogs ActivityLog[]

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt

}

model Board {
  id String @id @default(cuid())
  name String 
  description String?
  ownerId String
  owner User @relation(fields: [ownerId] , references: [id])
  isArchived Boolean @default(false)

  members BoardMember[]
  list List[]
  activityLogs ActivityLog[] 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

   @@index([ownerId])  
   @@index([isArchived]) 
}
enum ROLE {
  owner 
  editer
  viewer
}
model BoardMember {

  role ROLE @default(viewer)
  joinedAt DateTime @default(now())

  boardId String
  userId String

  board Board @relation(fields: [boardId] , references: [id])
  user User @relation(fields: [userId] , references: [id])


   @@id([boardId, userId])
}


model List {

  id String @id @default(cuid())
  title String
  position Float
  createdAt DateTime @default(now())
  boardId String
  board Board @relation(fields: [boardId] , references: [id])
   card Card[]
  @@index([boardId])
}
enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}
model Card {
  id String @id @default(cuid())
  title String
  description String?
  position Float
  embeddings Unsupported("vector(1536)")?
  priority Priority @default(NONE)
  dueDate DateTime?
  labels      String[]  @default([])
  completionListId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listId String
  assigneeId String?

  list List @relation(fields: [listId] , references: [id] ,  onDelete: Cascade)
  assignee User? @relation(fields: [assigneeId] , references: [id] , onDelete: SetNull)
   
  comments Comment[]
  @@index([listId])
  @@index([assigneeId])
}

model Comment {
  id String @id @default(cuid())
  message String
  createdAt DateTime @default(now())

  cardId String
  authorid String

  card Card @relation(fields: [cardId] , references: [id] , onDelete:Cascade)
  author User @relation(fields: [authorid] , references: [id] , onDelete: Restrict)
}

model ActivityLog {
  id         String   @id @default(uuid())
  action     String   @db.VarChar(50)  // 'card.created', 'card.moved', 'member.added'
  entityType String   @db.VarChar(20)  // 'card', 'list', 'board', 'comment'
  entityId   String                    // ID of the thing that was acted on
  metadata   Json     @default("{}")   // JSONB — flexible data per action type
  createdAt  DateTime @default(now())

  // Foreign keys
  boardId String
  userId  String

  // Relations
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([boardId])   // get all activity for a board
  @@index([createdAt]) // time-based queries, activity feed
  @@index([entityId])  // get all activity for a specific card/list
}