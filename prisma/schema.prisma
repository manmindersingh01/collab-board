generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users ────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatarUrl String?
  clerkId   String   @unique

  boardMember       BoardMember[]
  boards            Board[]
  cards             Card[]
  comments          Comment[]
  activityLogs      ActivityLog[]
  notifications     Notification[]
  workspaceMembers  WorkspaceMember[]
  apiKeys           ApiKey[]
  timeEntries       TimeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Workspaces ───────────────────────────────────────────

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model Workspace {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  logoUrl              String?
  plan                 Plan     @default(FREE)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique

  members WorkspaceMember[]
  boards  Board[]
  apiKeys ApiKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

enum WorkspaceRole {
  ADMIN
  MEMBER
  GUEST
}

model WorkspaceMember {
  role     WorkspaceRole @default(MEMBER)
  joinedAt DateTime      @default(now())

  workspaceId String
  userId      String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

// ── Boards ───────────────────────────────────────────────

model Board {
  id          String  @id @default(cuid())
  name        String
  description String?
  ownerId     String
  isArchived  Boolean @default(false)

  workspaceId String?

  owner     User       @relation(fields: [ownerId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  members           BoardMember[]
  list              List[]
  templates         CardTemplate[]
  activityLogs      ActivityLog[]
  automations       Automation[]
  integrations      Integration[]
  webhookEndpoints  WebhookEndpoint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([isArchived])
  @@index([workspaceId])
}

enum ROLE {
  owner
  editer
  viewer
}

model BoardMember {
  role     ROLE     @default(viewer)
  joinedAt DateTime @default(now())

  boardId String
  userId  String

  board Board @relation(fields: [boardId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@id([boardId, userId])
}

// ── Lists ────────────────────────────────────────────────

model List {
  id        String   @id @default(cuid())
  title     String
  position  Float
  createdAt DateTime @default(now())

  boardId String
  board   Board @relation(fields: [boardId], references: [id])

  card Card[]

  @@index([boardId])
}

// ── Cards ────────────────────────────────────────────────

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Card {
  id               String    @id @default(cuid())
  title            String
  description      String?
  position         Float
  embeddings       Unsupported("vector(1536)")?
  priority         Priority  @default(NONE)
  dueDate          DateTime?
  labels           String[]  @default([])
  completionListId String?
  isArchived       Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listId     String
  assigneeId String?

  list     List  @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignee User? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  comments    Comment[]
  timeEntries TimeEntry[]

  @@index([listId])
  @@index([assigneeId])
}

// ── Card Templates ───────────────────────────────────────

model CardTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  priority    Priority @default(NONE)
  labels      String[] @default([])

  boardId String
  board   Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([boardId])
}

// ── Comments ─────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  message   String
  createdAt DateTime @default(now())

  cardId   String
  authorid String

  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorid], references: [id], onDelete: Restrict)
}

// ── Notifications ────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String   @db.VarChar(50)
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ── Activity Log ─────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(uuid())
  action     String   @db.VarChar(50)
  entityType String   @db.VarChar(20)
  entityId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  boardId String
  userId  String

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([boardId])
  @@index([createdAt])
  @@index([entityId])
}

// ── Automations ─────────────────────────────────────────

model Automation {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  trigger   Json     // { event: "card.moved", conditions: { toList: "Done" } }
  actions   Json     // [{ type: "set_field", field: "assigneeId", value: null }]
  boardId   String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([boardId, isActive])
}

// ── Integrations ────────────────────────────────────────

model Integration {
  id        String   @id @default(cuid())
  type      String   @db.VarChar(20) // "slack", "github"
  config    Json     @default("{}")  // { webhookUrl, channel, token, repo, ... }
  isActive  Boolean  @default(true)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([boardId, type])
  @@index([boardId])
}

// ── API Keys ────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String    @db.VarChar(8)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isRevoked   Boolean   @default(false)

  workspaceId String
  createdById String

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id])

  createdAt   DateTime  @default(now())

  @@index([keyHash])
  @@index([workspaceId])
}

// ── Webhook Endpoints ───────────────────────────────────

model WebhookEndpoint {
  id          String   @id @default(cuid())
  url         String
  secret      String
  events      String[] @default([])
  isActive    Boolean  @default(true)

  boardId     String
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdById String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([boardId])
}

// ── Time Tracking ──────────────────────────────────────

model TimeEntry {
  id          String    @id @default(cuid())
  description String?
  startedAt   DateTime
  stoppedAt   DateTime?
  duration    Int?
  isManual    Boolean   @default(false)

  cardId String
  userId String

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([cardId])
  @@index([userId])
  @@index([userId, startedAt])
}
