# Database
DATABASE_URL=postgresql://myuser:mypassword@localhost:5432/mydb

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Redis
REDIS_URL=redis://localhost:6379

